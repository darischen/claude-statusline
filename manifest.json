{
  "manifest_version": 3,
  "name": "Claude Statusline",
  "version": "0.1.0",
  "description": "Always-on context, session, and weekly usage meters for claude.ai.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["usage.js", "context.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
